{
  "name": "social-skyline",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n server,worker \"npm run dev:server\" \"npm run dev:worker\"",
    "dev:server": "mkdir -p /tmp/social-skyline-tsx && TMPDIR=/tmp/social-skyline-tsx tsx server.ts",
    "dev:worker": "mkdir -p /tmp/social-skyline-tsx && TMPDIR=/tmp/social-skyline-tsx tsx workers/runMetricsWorker.ts",
    "build": "next build --webpack",
    "start": "NODE_ENV=production tsx server.ts",
    "worker": "tsx workers/runMetricsWorker.ts",
    "lint": "eslint"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/three": "^0.183.1",
    "bullmq": "^5.70.4",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
